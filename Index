<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Paint AI | Modern Painting Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --odassia-green: #769d3b;
            --odassia-burgundy: #a61d4c;
            --odassia-blue: #2b5d88;
            --odassia-gold: #a4772d;
        }

        body { 
            font-family: 'Poppins', sans-serif; 
            background-color: #ffffff; 
            overflow-x: hidden; 
            color: #333;
        }
        
        .art-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background-image: 
                linear-gradient(to right, rgba(118, 157, 59, 0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(118, 157, 59, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .btn-paint { transition: all 0.3s ease; }
        .btn-paint:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        
        .card-shadow { box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #eee; }
    </style>
</head>
<body>

    <div class="art-canvas"></div>

    <nav class="fixed top-0 w-full z-50 glass py-4">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <h1 class="text-2xl font-bold text-gray-800 tracking-tighter">SMART<span class="text-[#769d3b]">PAINT</span></h1>
            <div class="hidden md:flex gap-8 font-medium">
                <a href="#hero" class="hover:text-[#769d3b] transition">Home</a>
                <a href="#calculator" class="hover:text-[#769d3b] transition">Cost Calculator</a>
                <a href="#solutions" class="hover:text-[#769d3b] transition">Our Solutions</a>
                <a href="#visualizer" class="hover:text-[#769d3b] transition font-bold">AI Visualizer</a>
            </div>
            <a href="https://wa.me/212600000000" class="bg-[#769d3b] text-white px-5 py-2 rounded-full flex items-center gap-2 btn-paint">
                <span>WhatsApp</span>
            </a>
        </div>
    </nav>

    <main class="pt-24">
        <section id="hero" class="container mx-auto px-6 py-20 text-center">
            <div class="inline-block bg-green-50 text-[#769d3b] px-4 py-1 rounded-full text-sm font-bold mb-6 border border-green-100">
                Team of certified technicians with extensive experience
            </div>
            <h2 class="text-5xl md:text-7xl font-bold mb-6 text-gray-900 leading-tight">
                Turn your home into a <span class="text-[#a4772d] italic">Masterpiece</span>
            </h2>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10 leading-relaxed">
                We combine high quality with environmental respect in every project. Professional painting, modern decor, and innovative solutions.
            </p>
            <div class="flex flex-col md:flex-row justify-center gap-4">
                <a href="#calculator" class="bg-[#769d3b] text-white px-8 py-4 rounded-xl font-bold btn-paint shadow-lg shadow-green-200">Estimate Your Project</a>
                <a href="#visualizer" class="border-2 border-gray-800 text-gray-800 px-8 py-4 rounded-xl font-bold btn-paint">Try AI Color Visualizer</a>
            </div>
        </section>

        <section id="solutions" class="container mx-auto px-6 py-20">
            <h3 class="text-3xl font-bold mb-12 text-center uppercase tracking-widest">Solutions for Your Painting Issues</h3>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="flex flex-col md:flex-row bg-white card-shadow overflow-hidden rounded-2xl">
                    <div class="bg-[#769d3b] text-white p-8 flex flex-col justify-center md:w-1/2 text-left">
                        <h4 class="text-xl font-bold mb-4">Humidity & Mold</h4>
                        <p class="text-sm opacity-90 mb-4">Effective solutions to get rid of wall dampness and mold.</p>
                        <button class="border-2 border-white px-4 py-1 self-start text-xs font-bold hover:bg-white hover:text-[#769d3b] transition">Discover</button>
                    </div>
                    <div class="md:w-1/2 h-48 bg-gray-100">
                        <img src="https://media.istockphoto.com/id/1400305398/fr/photo/b%C3%A2timents-humides-endommag%C3%A9s-par-la-moisissure-noire-et-les-champignons-lhumidit%C3%A9-ou-leau.webp?s=612x612&w=is&k=20&c=u6_sSgebJyeIcvGnB1LKZkM5Dm9YBCC5Jd1xWNecBpo=" alt="Humidity Treatment" class="w-full h-full object-cover">
                    </div>
                </div>

                <div class="flex flex-col md:flex-row bg-white card-shadow overflow-hidden rounded-2xl">
                    <div class="bg-[#a61d4c] text-white p-8 flex flex-col justify-center md:w-1/2 text-left">
                        <h4 class="text-xl font-bold mb-4">Matte or Satin?</h4>
                        <p class="text-sm opacity-90 mb-4">Choosing the right finish for every room in your home.</p>
                        <button class="border-2 border-white px-4 py-1 self-start text-xs font-bold hover:bg-white hover:text-[#a61d4c] transition">Discover</button>
                    </div>
                    <div class="md:w-1/2 h-48 bg-gray-100">
                        <img src="https://media.istockphoto.com/id/2205924130/fr/photo/mur-de-b%C3%A9ton-fond-textur%C3%A9-peinture-abstraite-bleu-et-blanc.jpg?s=1024x1024&w=is&k=20&c=fS_ZPa5gMxRvaGVsZQWbT0D8BlWYoura6NxTr-ZdTo8=" alt="Matte and Satin Finishes" class="w-full h-full object-cover">
                    </div>
                </div>
            </div>
        </section>

        <section id="calculator" class="container mx-auto px-6 py-20">
            <div class="bg-white p-8 md:p-12 rounded-3xl max-w-4xl mx-auto card-shadow border-t-8 border-[#769d3b]">
                <h3 class="text-3xl font-bold mb-8 text-center text-gray-800">Estimated Budget Calculator</h3>
                <div class="grid md:grid-cols-2 gap-8">
                    <div class="text-left">
                        <label class="block text-xs font-bold mb-2 uppercase text-gray-500">Total Wall Area (m²)</label>
                        <input type="number" id="areaInput" placeholder="Example: 50" class="w-full p-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#769d3b] outline-none transition">
                    </div>
                    <div class="text-left">
                        <label class="block text-xs font-bold mb-2 uppercase text-gray-500">Select Paint Type</label>
                        <select id="paintType" class="w-full p-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#769d3b] outline-none appearance-none bg-white">
                            <option value="85">Satiné (Satin) - 85 MAD/m²</option>
                            <option value="45">Vinyl - 45 MAD/m²</option>
                            <option value="150">Special Decor (Stucco/Khayal) - 150 MAD/m²</option>
                        </select>
                    </div>
                </div>
                <div class="mt-10 p-8 bg-gray-50 rounded-2xl flex flex-col md:flex-row justify-between items-center border-l-8 border-[#a4772d]">
                    <div class="mb-4 md:mb-0 text-left">
                        <p class="text-gray-500 text-sm font-bold">Estimated Cost (MAD):</p>
                        <div class="text-5xl font-bold text-gray-800"><span id="totalCost">0</span> <span class="text-xl">MAD</span></div>
                    </div>
                    <button onclick="calculateCost()" class="bg-black text-white px-10 py-4 rounded-xl font-bold hover:bg-[#769d3b] transition-all">Calculate Cost</button>
                </div>
            </div>
        </section>

        <section id="visualizer" class="container mx-auto px-6 py-20 pb-40">
            <div class="bg-[#1a1a1a] text-white rounded-[3rem] p-10 md:p-20 overflow-hidden relative">
                <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
                    <div class="text-left">
                        <h3 class="text-4xl font-bold mb-6">Visualize Before You Start!</h3>
                        <p class="text-gray-400 mb-8 text-lg">Upload a photo of your room and use AI to change colors and preview the final result in seconds.</p>
                        <div class="flex flex-col gap-4">
                            <label class="cursor-pointer bg-[#769d3b] text-white px-8 py-4 rounded-xl font-bold text-center hover:bg-green-700 transition">
                                <input type="file" class="hidden" onchange="simulateUpload(this)">
                                Upload Room Photo
                            </label>
                            <p id="uploadStatus" class="text-[#a4772d] font-medium"></p>
                        </div>
                    </div>
                    <div class="aspect-video bg-gray-800 rounded-2xl flex items-center justify-center overflow-hidden border-2 border-dashed border-gray-700">
                        <img id="placeholderImg" src="https://media.istockphoto.com/id/1254414808/photo/color-guide-on-a-white-background.jpg?s=1024x1024&w=is&k=20&c=XPyN1CZVfiEjanJf9-itaoyh5W0SAC3wcoc7jU47xmg=" alt="Color Guide" class="w-full h-full object-cover">
                        <img id="previewImg" class="hidden w-full h-full object-cover">
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="bg-gray-50 py-12 border-t">
        <div class="container mx-auto px-6 text-center">
            <h4 class="text-xl font-bold text-gray-800 mb-4 tracking-tighter">SMART<span class="text-[#769d3b]">PAINT</span></h4>
            <p class="text-sm text-gray-500 italic">© 2026 Smart Paint AI - Excellence in Every Detail.</p>
        </div>
    </footer>

    <script>
        function calculateCost() {
            const area = document.getElementById('areaInput').value;
            const price = document.getElementById('paintType').value;
            const totalDisplay = document.getElementById('totalCost');
            
            if(area > 0) {
                const total = area * price;
                let start = 0;
                const timer = setInterval(() => {
                    start += total / 50;
                    if (start >= total) {
                        totalDisplay.innerText = Math.round(total).toLocaleString();
                        clearInterval(timer);
                    } else {
                        totalDisplay.innerText = Math.round(start).toLocaleString();
                    }
                }, 10);
            } else {
                alert("Please enter the wall area first");
            }
        }

        function simulateUpload(input) {
            const status = document.getElementById('uploadStatus');
            const preview = document.getElementById('previewImg');
            const placeholder = document.getElementById('placeholderImg');
            
            if (input.files && input.files[0]) {
                status.innerText = "Analyzing image with AI...";
                const reader = new FileReader();
                reader.onload = function(e) {
                    setTimeout(() => {
                        preview.src = e.target.result;
                        preview.classList.remove('hidden');
                        placeholder.classList.add('hidden');
                        status.innerText = "Analysis complete! You can now experiment with colors.";
                    }, 1500);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>